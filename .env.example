# === Zé do CAR — variáveis de ambiente ===
# Copie este arquivo para .env.local e preencha sua chave.

# Chave da OpenAI (obrigatória). Pegue em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelos (opcionais — já têm padrão sensato)
# Troque para gpt-4o se quiser a máxima qualidade nas respostas.
ZE_CHAT_MODEL=gpt-4o-mini
ZE_EMBEDDING_MODEL=text-embedding-3-small
ZE_STT_MODEL=whisper-1
ZE_TTS_MODEL=gpt-4o-mini-tts
# Vozes: alloy, echo, fable, onyx, nova, shimmer, verse
ZE_TTS_VOICE=alloy

# === WhatsApp via Twilio ===
# Ative o WhatsApp Sandbox em: Console Twilio > Messaging > Try it out > WhatsApp.
# Configure o webhook "When a message comes in" (POST) para:
#   https://SEU_DOMINIO_PUBLICO/api/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número do sandbox do WhatsApp (aparece no console). Ex.: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# URL pública (túnel local). Na Vercel, deixe vazio — usa VERCEL_URL automaticamente.
# Ex.: https://algo-aleatorio.trycloudflare.com
PUBLIC_BASE_URL=

# Enviar resposta também em áudio (nota de voz) no WhatsApp. true/false.
ZE_WHATSAPP_AUDIO=true
# Validar a assinatura das requisições do Twilio (mais seguro). true/false.
TWILIO_VALIDATE=false
